# Frontend Environment Variables

# Backend API URL
# In Production (VPS with Nginx), leave this empty or unset to default to same-origin '/api'
# In Local Development, set this to 'http://localhost:3001/api' if your backend runs on port 3001
VITE_API_URL=http://localhost:3001/api

# Feature flags
VITE_TELEGRAM_BOT_ENABLED=true
